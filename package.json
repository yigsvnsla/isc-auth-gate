{
  "name": "isc-auth-gate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "auth:generate": "bun x auth@latest generate --config ./lib/auth.ts --output ./database/schema.ts --yes",
    "database:up": "bun x drizzle-kit up",
    "database:push": "bun x drizzle-kit push",
    "database:check": "bun x drizzle-kit check",
    "database:generate": "bun x drizzle-kit generate",
    "database:studio": "bunx --bun drizzle-kit studio --port 4001 --verbose",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "seed:run": "bun run tests/seed.ts seed",
    "seed:reset": "bun run tests/seed.ts reset"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@better-auth/drizzle-adapter": "^1.6.11",
