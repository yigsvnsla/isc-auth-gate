    "@types/bun": "^1.3.14",
    "@types/lodash.debounce": "^4.0.9",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^20.19.41",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "swr-devtools": "^1.3.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3"
